    "print(A)\n",
    "print(A_1)\n",
    "H = 10\n",
    "A_2 = np.zeros((N,N))\n",
    "for k in range(N):\n",
    "  A_2[:N-k,k] = H\n",
    "  H -= 1\n",
    "print(A_2)"
